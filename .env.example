# FinBuddy Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to Git (it is already in .gitignore)

# =============================================================================
# Google Gemini / Google AI Studio (REQUIRED for ADK mode)
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-ai-studio-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=4096

# =============================================================================
# OpenAI (Legacy Fallback — optional if using ADK)
# =============================================================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.1
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# =============================================================================
# Agent Framework Selection
# "adk" = Google ADK + Gemini (recommended for Kaggle submission)
# "langchain" = Legacy LangChain + OpenAI (backward compatible)
# =============================================================================
AGENT_FRAMEWORK=adk

# =============================================================================
# Database (PostgreSQL with asyncpg)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finbuddy
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# Redis (Cache + Celery Broker + Rate Limiting)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Security (REQUIRED for production)
# =============================================================================
# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-32-byte-base64-fernet-key-here=
PII_REDACTION_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
AUDIT_LOGGING_ENABLED=true

# =============================================================================
# ChromaDB (Vector Store for RAG)
# =============================================================================
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=finbuddy_knowledge

# =============================================================================
# Market Data APIs
# =============================================================================
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
YAHOO_FINANCE_ENABLED=true

# =============================================================================
# Bank Integration (Plaid)
# =============================================================================
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# =============================================================================
# News APIs
# =============================================================================
NEWS_API_KEY=your-newsapi-key
FINNHUB_API_KEY=your-finnhub-key

# =============================================================================
# OCR
# =============================================================================
OCR_PROVIDER=openai
TESSERACT_PATH=/usr/bin/tesseract

# =============================================================================
# CORS (Frontend origins)
# =============================================================================
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Application
# =============================================================================
APP_NAME=FinBuddy
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=your-super-secret-app-key-change-in-production
